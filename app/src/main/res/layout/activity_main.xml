<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="30dp"
        android:src="@drawable/q_logo" /> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Internal Menu v1.0"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="40dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swNoRecoil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Recoil (무반동)"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swNoSpread"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Spread (탄퍼짐 제거)"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="40dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swAimbot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Magnet Aimbot (자석 에임)"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:id="@+id/txtFovStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aimbot FOV: 20"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="5dp"/>

    <SeekBar
        android:id="@+id/sbAimbotFov"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="20"
        android:layout_marginBottom="20dp"/>

</LinearLayout>
